# Copy to .env and fill in. NEVER commit the real .env (blocked by .gitignore).
# Generate secrets with:  openssl rand -base64 32

# ─── Platform ───────────────────────────────────────────────
# Your Tailscale MagicDNS hostname (e.g. houseos.tailXXXX.ts.net).
# Keep the REAL value out of git — it lives only in your local .env.
PLATFORM_HOST=your-machine.your-tailnet.ts.net

# ─── PocketBase (tickets backend) ───────────────────────────
PB_ADMIN_EMAIL=you@example.com
PB_ADMIN_PASSWORD=change_me_use_a_password_manager
PB_ENCRYPTION_KEY=generate_a_32_char_random_string

# ─── Web Push (VAPID) ───────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ─── SMTP (password resets / reminders) ─────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=tickets@example.com

# ─── Backups ────────────────────────────────────────────────
RESTIC_REPOSITORY=
RESTIC_PASSWORD=

# ─── Network module (analyzer dashboard) ────────────────────
DASHBOARD_PASSWORD=
DASHBOARD_SECRET_KEY=
