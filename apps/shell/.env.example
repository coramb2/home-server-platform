# Copy to .env for local dev. The real .env is gitignored.
# Points the frontend at your local PocketBase during development.
# In production this is unset — the app calls same-origin /api/tickets via Caddy.
VITE_PB_URL=http://127.0.0.1:8090

# Web Push public (VAPID) key — safe to expose. Generate a pair with:
#   npx web-push generate-vapid-keys
# (the private key goes only in modules/push/.env, never here)
VITE_VAPID_PUBLIC_KEY=
