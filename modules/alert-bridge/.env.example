# Copy to .env (gitignored).
PB_URL=http://127.0.0.1:8090
PB_ADMIN_EMAIL=admin@house.local
PB_ADMIN_PASSWORD=change_me

# The network-traffic-analyzer dashboard (its /api needs session auth).
ANALYZER_URL=http://127.0.0.1:8080
ANALYZER_PASSWORD=change_me

POLL_SECONDS=60
RUNS_TO_SCAN=5
# Optional: a PocketBase user id to assign security tickets to (triggers a push
# to that person). Leave empty to keep them unassigned = no notification spam.
SECURITY_ASSIGNEE=
