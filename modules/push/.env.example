# Copy to .env (gitignored). Generate the VAPID pair once with:
#   npx web-push generate-vapid-keys
# The PUBLIC key must also be set as VITE_VAPID_PUBLIC_KEY in apps/shell/.env.
PB_URL=http://127.0.0.1:8090
PB_ADMIN_EMAIL=admin@house.local
PB_ADMIN_PASSWORD=change_me
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
